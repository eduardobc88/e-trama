{
	"editor.bracketPairColorization.independentColorPoolPerBracketType": true,
	"editor.fontSize": 12,
	"editor.lineHeight": 1.7,
	"workbench.colorTheme": "Jetbrains Fleet",
	"editor.autoIndent": "none",
	"editor.detectIndentation": false,
	"editor.tabSize": 2,
	"editor.autoIndentOnPasteWithinString": false,
	"editor.insertSpaces": true,
	"editor.find.addExtraSpaceOnTop": true,
	"editor.comments.insertSpace": false,
	"editor.formatOnSave": false,
	"editor.renderWhitespace": "all",
	"vue.inlayHints.optionsWrapper": true,
  "editor.tabCompletion": "on",
  "workbench.auxiliaryActivityBar.location": "top",
  "workbench.activityBar.location": "top",
  "window.autoDetectColorScheme": true,
  "workbench.preferredLightColorTheme": "Xcode Classic Light",
  "workbench.preferredDarkColorTheme": "Jetbrains Fleet",
  "workbench.preferredHighContrastColorTheme": "Xcode Default Dark",
  "workbench.preferredHighContrastLightColorTheme": "Xcode Classic Light"
}