<!DOCTYPE html>
<html>
    <head>
        <title><%= title -%></title>
        <meta charset="utf-8">
        <link rel="apple-touch-icon" sizes="180x180" href="<%= serviceStaticPath -%>assets/apple-touch-icon.png">
        <link rel="icon" type="image/png" sizes="32x32" href="<%= serviceStaticPath -%>assets/favicon-32x32.png">
        <link rel="icon" type="image/png" sizes="16x16" href="<%= serviceStaticPath -%>assets/favicon-16x16.png">
        <!--<link rel="manifest" href="assets/site.webmanifest">-->
        <link rel="mask-icon" href="<%= serviceStaticPath -%>assets/safari-pinned-tab.svg" color="#ffffff">
        <meta name="msapplication-TileColor" content="#ffffff">
        <meta name="theme-color" content="#ffffff">
        <meta
          name="viewport"
          content="width=device-width, initial-scale=1">
        <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" />
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Google+Sans:ital,opsz,wght@0,17..18,400..700;1,17..18,400..700&display=swap" rel="stylesheet">
    </head>
    <body>
        <style>
            html,
            body {
              min-width: 100% !important;
              max-width: 100% !important;
            }
            html {
              box-sizing: border-box;
              height: 100%;
              overflow: hidden;
            }
            body {
              background-color: #ffffff;
              box-sizing: border-box;
              font-family: "Google Sans", sans-serif;
              height: 100%;
              margin: 0;
              overflow: hidden;
            }
            input,
            textarea,
            button,
            a {
              font-family: "Google Sans", sans-serif;
            }
            a,
            textarea,
            input[type=text]:focus {
              outline: none !important;
              outline-offset: 0 !important;
            }
            ::selection {
              background: var(--main-accent-color);
              color: white;
            }
            ::-moz-selection {
              background: var(--main-accent-color);
              color: white;
            }
        </style>
        <div id="app"></div>
        <script
          defer
          src="https://cdn.socket.io/4.1.1/socket.io.min.js"
          crossorigin="anonymous">
        </script>
        <script
          defer
          src="<%= serviceStaticPath -%>js/github-widget.js">
        </script>
    </body>
</html>
