<!doctype html>
<html lang="es">
  <head>
    <title>
      <%= title %>
    </title>
    <meta charset="utf-8">
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1">
    <meta
      name="theme-color"
      content="#ffffff">
    <meta name="msapplication-TileColor" content="#ffffff">
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet">
    <link
      href="/static/css/admin-login.css"
      rel="stylesheet">
  </head>
  <body>
    <div id="header">
    </div>
    <div class="wrapper">
      <div class="login-form-wrapper">
        <h1>
          <%= title %>
        </h1>
        <p id="description">enter your email address and we will you a email with the instrucctions to recover your account</h2>
        <form
          action="/recover-account"
          method="POST"
          autocomplete="new-password"
          >
          <input
            type="hidden"
            name="_csrf"
            value="<%- csrfToken -%>"
            />
          <div class="input-text">
            <input
              type="text"
              name="email_address"
              autocomplete="new-password"
              onfocus="onInputFocus(this)"
              onblur="onInputFocus(this)"
              required
              />
            <label>email</label>
            <span class="hint">your email address</span>
          </div>
          <button
            class="button"
            type="submit"
            >
            send
          </button>
          <p id="error-msg">
            <%= error_message %>
          </p>
          <p id="success-msg">
            <%= success_message %>
          </p>
        </form>
      </div>
    </div>
    <div id="footer">
      <span>
        development by
      </span>
      <div
        class="github-widget"
        data-github="eduardobc88">
      </div>
      <span>
        version 1.0.0
      </span>
    </div>
    <script src='/static/js/dashboard-login.js' charset="utf-8"></script>
    <script
      defer
      src="/static/js/github-widget.js">
    </script>
  </body>
</html>
